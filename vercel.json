{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron-fetch", "schedule": "0 0 * * *" },
    { "path": "/api/cron-fetch", "schedule": "0 8 * * *" },
    { "path": "/api/cron-fetch", "schedule": "0 16 * * *" },
    { "path": "/api/cron-dominance", "schedule": "30 0 * * *" }
  ],
  "functions": {
    "api/cron-fetch.js": { "maxDuration": 300 },
    "api/cron-dominance.js": { "maxDuration": 300 },
    "api/backfill-dominance.js": { "maxDuration": 300 },
    "api/import-market-history.js": { "maxDuration": 300, "includeFiles": "data/market_history.csv.gz" },
    "api/import-btc-intraday.js": { "maxDuration": 300 },
    "api/backfill.js": { "maxDuration": 300 },
    "api/backfill-token.js": { "maxDuration": 300 },
    "api/recompute-emissions.js": { "maxDuration": 300 }
  }
}
